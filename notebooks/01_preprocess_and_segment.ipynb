<VSCode.Cell language="markdown">
# 01. Preprocess LANL Data and Segment Failure Cycles

This notebook loads the LANL dataset with the LANL loader, builds proxy state variables, and segments the continuous time series by resets in `time_to_failure`.

Proxy definitions for this baseline:
- `tau_proxy = smoothed acoustic_data`
- `V_proxy = derivative of tau_proxy`
</VSCode.Cell>
<VSCode.Cell language="python">
import sys
from pathlib import Path
import pandas as pd
import matplotlib.pyplot as plt

sys.path.insert(0, str(Path.cwd().parent))
from src import io, preprocess, segmentation

train_path = Path('data/train.csv')
if not train_path.exists():
    raise FileNotFoundError('Expected LANL dataset at data/train.csv.')

raw_df = io.load_lanl_train(str(train_path), nrows=None)
print(f'Loaded raw LANL data shape: {raw_df.shape}')
print(raw_df.head())

clean_df = preprocess.clean_lanl_dataframe(raw_df)
print(f'Cleaned LANL dataframe shape: {clean_df.shape}')
</VSCode.Cell>
<VSCode.Cell language="python">
processed_df = preprocess.build_proxy_state(
    clean_df,
    acoustic_col='acoustic_data',
    tau_col='tau_proxy',
    v_col='V_proxy',
    smooth_window=101,
    smooth_polyorder=3,
    derivative_method='central'
)
print('Processed columns:', list(processed_df.columns))
print(processed_df[['tau_proxy', 'V_proxy']].head())

processed_path = Path('data/lanl_train_processed.csv')
processed_df.to_csv(processed_path, index=False)
print(f'Processed LANL dataset saved to: {processed_path.resolve()}')
</VSCode.Cell>
<VSCode.Cell language="python">
cycles = segmentation.segment_by_failure_resets(processed_df, ttf_col='time_to_failure', min_cycle_length=1000)
print(f'Found {len(cycles)} cycles via time_to_failure resets.')
for idx, (start, end) in enumerate(cycles[:5]):
    print(f'  Cycle {idx}: start={start}, end={end}, length={end-start}')

if len(cycles) == 0:
    raise RuntimeError('No LANL cycles were detected. Check the data or min_cycle_length.')

first_start, first_end = cycles[0]
cycle_df = processed_df.iloc[first_start:first_end].reset_index(drop=True)
cycle_path = Path('data/lanl_cycle_0.csv')
cycle_df.to_csv(cycle_path, index=False)
print(f'Saved first LANL cycle to: {cycle_path.resolve()}')
</VSCode.Cell>
<VSCode.Cell language="python">
fig, axes = plt.subplots(3, 1, figsize=(14, 10), sharex=True)
axes[0].plot(processed_df['time'], processed_df['tau_proxy'], color='tab:blue', linewidth=0.4)
axes[0].set_ylabel('tau_proxy')
axes[0].set_title('LANL tau_proxy (smoothed acoustic_data)')
axes[0].grid(True, alpha=0.3)

axes[1].plot(processed_df['time'], processed_df['V_proxy'], color='tab:green', linewidth=0.4)
axes[1].set_ylabel('V_proxy')
axes[1].set_title('LANL V_proxy (derivative of tau_proxy)')
axes[1].grid(True, alpha=0.3)

axes[2].plot(processed_df['time'], processed_df['time_to_failure'], color='tab:red', linewidth=0.8)
for start, end in cycles[:5]:
    axes[2].axvline(processed_df['time'].iloc[start], color='black', linestyle='--', alpha=0.4)
axes[2].set_ylabel('time_to_failure')
axes[2].set_xlabel('time')
axes[2].set_title('LANL failure cycles and reset boundaries')
axes[2].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()
</VSCode.Cell>
